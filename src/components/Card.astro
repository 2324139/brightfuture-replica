---
interface Props {
  title: string;
  description: string;
  year?: string;
  image?: string;
}

const { title, description, year, image } = Astro.props;
---

<div class="card">
  {image && <img src={image} alt={title} class="card-image" />}
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    {year && <span class="card-year">{year}</span>}
    <p class="card-description">{description}</p>
  </div>
</div>

<style>
  .card {
    background: white;
    border-left: 4px solid var(--primary);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-title {
    color: var(--primary);
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }

  .card-year {
    display: inline-block;
    background-color: var(--secondary);
    color: var(--primary);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .card-description {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
