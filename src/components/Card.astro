---
interface Props {
  name: string;
  year: string;
  field?: string;
  image?: string;
}

const { name, year, field, image } = Astro.props;
---

<div class="scholar-card">
  <div class="card-image">
    {image ? (
      <img src={image} alt={name} />
    ) : (
      <div class="placeholder"></div>
    )}
  </div>
  <div class="card-content">
    <h3 class="card-name">{name}</h3>
    <span class="card-year">{year}</span>
    {field && <p class="card-field">{field}</p>}
  </div>
</div>

<style>
  .scholar-card {
    background: var(--color-white);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .scholar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }

  .card-image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-gray-light);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .scholar-card:hover .card-image img {
    transform: scale(1.05);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8e8 0%, #f5f5f5 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder::after {
    content: '';
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(0,0,0,0.05);
  }

  .card-content {
    padding: 20px 16px;
    text-align: center;
  }

  .card-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .card-year {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .card-field {
    font-size: 0.85rem;
    color: var(--color-gray);
    margin-top: 8px;
  }
</style>
