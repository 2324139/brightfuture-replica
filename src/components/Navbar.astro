---
const navLinks = [
  { href: '/', label: '首頁' },
  { href: '/about', label: '關於獎學金' },
  { href: '/scholars', label: '歷屆得獎者' },
  { href: '/apply', label: '申請資訊' },
];
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-cn">鵬程創意獎學金</span>
      <span class="logo-en">BFCS</span>
    </a>
    
    <nav class="nav">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <button class="mobile-toggle" aria-label="選單">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--color-white);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    z-index: 1000;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-cn {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.15em;
  }

  .logo-en {
    font-size: 0.7rem;
    color: var(--color-gray);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    gap: 2.5rem;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    padding: 8px 0;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .mobile-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    transition: 0.3s;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }
    
    .mobile-toggle {
      display: flex;
    }
  }
</style>
