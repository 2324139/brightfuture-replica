---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/Card.astro';

const scholars = [
  { name: '李心悅', year: '2019', field: '視覺藝術' },
  { name: '李雅斯', year: '2019', field: '媒體藝術' },
  { name: '鍾咏琛', year: '2020', field: '視覺藝術' },
  { name: '馬敏翹', year: '2020', field: '表演藝術' },
  { name: '謝貝怡', year: '2020', field: '媒體藝術' },
  { name: '梁柏麟', year: '2020', field: '音樂' },
];
---

<Layout title="鵬程創意獎學金 | BFCS">
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <p class="hero-school">香港兆基創意書院</p>
        <h1 class="hero-title">鵬程創意獎學金</h1>
        <p class="hero-en">Bright Future Creativity Scholarship</p>
        <div class="hero-line"></div>
        <p class="hero-desc">
          嘉許在藝術創作方面有傑出表現的同學
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="section about">
      <div class="container">
        <h2 class="section-title">關於獎學金</h2>
        <p class="section-subtitle">About the Scholarship</p>
        <div class="about-content">
          <p>
            鵬程創意獎學金由鍾志平教授於2018年成立，旨在嘉許在藝術創作方面有傑出表現的香港兆基創意書院同學，鼓勵學生發揮創意潛能，追求藝術卓越。
          </p>
        </div>
      </div>
    </section>

    <!-- Scholars Section -->
    <section class="section scholars-section">
      <div class="container">
        <h2 class="section-title">歷屆得獎者</h2>
        <p class="section-subtitle">Awardees</p>
        
        <div class="scholars-grid">
          {scholars.map(scholar => (
            <Card 
              name={scholar.name} 
              year={scholar.year} 
              field={scholar.field}
            />
          ))}
        </div>
        
        <div class="view-more">
          <a href="/scholars" class="btn">查看更多得獎者</a>
        </div>
      </div>
    </section>

    <!-- Apply Section -->
    <section class="section apply-section">
      <div class="container">
        <div class="apply-box">
          <h2>成為獎學金得主</h2>
          <p>現正就讀香港兆基創意書院的中四至中六學生均可申請</p>
          <a href="/apply" class="btn btn-light">了解申請詳情</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    padding-top: var(--header-height);
  }

  /* Hero */
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    background: linear-gradient(180deg, #fafafa 0%, #ffffff 100%);
  }

  .hero-content {
    max-width: 600px;
  }

  .hero-school {
    font-size: 0.9rem;
    color: var(--color-gray);
    letter-spacing: 0.2em;
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }

  .hero-en {
    font-size: 0.85rem;
    color: var(--color-secondary);
    letter-spacing: 0.1em;
    margin-bottom: 32px;
  }

  .hero-line {
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    margin: 0 auto 32px;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.8;
  }

  /* About */
  .about {
    background: var(--color-white);
  }

  .about-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .about-content p {
    font-size: 1.05rem;
    line-height: 2;
    color: var(--color-text);
  }

  /* Scholars */
  .scholars-section {
    background: var(--color-gray-light);
  }

  .scholars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 24px;
    margin-bottom: 48px;
  }

  .view-more {
    text-align: center;
  }

  .btn {
    display: inline-block;
    padding: 14px 32px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    background: transparent;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  /* Apply */
  .apply-section {
    background: var(--color-white);
  }

  .apply-box {
    background: var(--color-secondary);
    color: var(--color-white);
    padding: 60px 40px;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .apply-box h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-white);
    margin-bottom: 16px;
    letter-spacing: 0.1em;
  }

  .apply-box p {
    font-size: 0.95rem;
    opacity: 0.9;
    margin-bottom: 32px;
  }

  .btn-light {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .btn-light:hover {
    background: var(--color-white);
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 60vh;
    }

    .scholars-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .apply-box {
      padding: 40px 24px;
    }
  }
</style>
